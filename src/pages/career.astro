---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ExperienceTimeline from "@components/ExperienceTimeline.astro";
import EducationList from "@components/EducationList.astro";
import EventList from "@components/EventList.astro";
import { experience } from "@data/experience";
import { education } from "@data/education";
import { events } from "@data/events";
import { SITE } from "@config";
import Breadcrumbs from "@components/Breadcrumbs.astro";
---

<Layout
  title={`Career | ${SITE.title}`}
  description="Career history, education, and conferences of Hendrik Prinsloo — technical lead and full stack developer based in Amsterdam."
>
  <Header activeNav="career" />
  <Breadcrumbs />

  <main id="main-content">
    <section class="page-section pt-8">
      <ExperienceTimeline entries={experience} />
    </section>

    <section class="page-section">
      <SectionHeading title="Education" />
      <EducationList entries={education} />
    </section>

    <section id="conferences" class="page-section">
      <SectionHeading title="Conferences" />
      <EventList entries={events} />
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-section {
    @apply pb-8 pt-6;
  }
  .page-title {
    @apply text-3xl font-bold;
  }
  .page-desc {
    @apply mt-2 opacity-80;
  }
</style>
