---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Card from "@components/Card";
import SectionHeading from "@components/SectionHeading.astro";
import ExperienceTimeline from "@components/ExperienceTimeline.astro";
import ArticleList from "@components/ArticleList.astro";
import ProjectList from "@components/ProjectList.astro";
import FadeIn from "@components/FadeIn.astro";
import getSortedPosts from "@utils/getSortedPosts";
import getSortedProjects from "@utils/getSortedProjects";
import RecentPhotos from "@components/gallery/RecentPhotos.svelte";
import { getContentSlug } from "@utils/getContentSlug";
import { fetchRecentPhotos, recentPhotos } from "@stores/galleryStore";
import { profile } from "@data/profile";
import { experience } from "@data/experience";
import { articles } from "@data/articles";
import { SITE } from "@config";
import { personSchema, webSiteSchema } from "@utils/seo";

type UnsplashPhoto = {
  id: string;
  width: number;
  height: number;
  alt_description?: string | null;
  description?: string | null;
  urls: {
    full: string;
    thumb: string;
  };
};

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const projects = await getCollection("projects");
const sortedProjects = getSortedProjects(projects);

await fetchRecentPhotos(16);
const recentPhotoItems = Object.values(
  recentPhotos.get() as Record<string, UnsplashPhoto>
).map(photo => ({
  id: photo.id,
  width: photo.width,
  height: photo.height,
  alt: photo.alt_description ?? photo.description ?? "",
  urls: {
    full: photo.urls.full,
    thumb: photo.urls.thumb,
  },
}));
---

<Layout
  title={`${profile.name} | ${profile.title}`}
  description={SITE.desc}
  structuredData={[webSiteSchema(), personSchema()]}
>
  <Header />
  <main id="main-content">
    <section id="hero">
      <FadeIn>
        <p class="hero-headline">{profile.headline}</p>
        <p class="hero-bio">{profile.bio}</p>
      </FadeIn>
      <FadeIn delay={200}>
        <RecentPhotos photos={recentPhotoItems} client:visible />
        <div class="section-link">
          <LinkButton href="/gallery/" showArrow={true}>Gallery</LinkButton>
        </div>
      </FadeIn>
    </section>

    <section id="career">
      <FadeIn delay={50}>
        <SectionHeading title="Career" />
        <ExperienceTimeline entries={experience} limit={2} />
        <div class="section-link">
          <LinkButton href="/career/" showArrow={true}>
            Full career
          </LinkButton>
        </div>
      </FadeIn>
    </section>

    <section id="projects">
      <FadeIn delay={100}>
        <SectionHeading title="Projects" />
        <ProjectList projects={sortedProjects} limit={4} />
        <div class="section-link">
          <LinkButton href="/projects/" showArrow={true}>
            All projects
          </LinkButton>
        </div>
      </FadeIn>
    </section>

    <section id="writing">
      <FadeIn delay={150}>
        <SectionHeading title="Writing" />
        <ArticleList entries={articles} limit={3} />
        <div class="section-link">
          <LinkButton
            href="https://medium.com/@hendrikprinsza"
            showArrow={true}
          >
            All articles on Medium
          </LinkButton>
        </div>
      </FadeIn>
    </section>

    {
      recentPosts.length > 0 && (
        <section id="recent-posts">
          <FadeIn delay={250}>
            <SectionHeading title="Recent posts" />
            <ul>
              {recentPosts.map(
                (post, index) =>
                  index < 4 && (
                    <Card
                      href={`/posts/${getContentSlug(post)}/`}
                      frontmatter={post.data}
                      secHeading={false}
                      showTime={false}
                    />
                  )
              )}
            </ul>
            <div class="section-link">
              <LinkButton href="/posts/" showArrow={true}>
                All posts
              </LinkButton>
            </div>
          </FadeIn>
        </section>
      )
    }
  </main>

  <Footer />
</Layout>

<style>
  #hero {
    @apply border-skin-line pb-10 pt-8;
  }
  #hero h1 {
    @apply text-3xl font-bold tracking-tight sm:text-4xl;
  }
  .hero-subtitle {
    @apply mt-1 text-lg text-skin-accent;
  }
  .hero-headline {
    @apply mt-4 max-w-2xl text-base opacity-90;
  }
  .hero-bio {
    @apply mt-3 max-w-2xl text-sm opacity-75;
  }
  .tech-tags {
    @apply mt-5 flex list-none flex-wrap gap-2 p-0;
  }
  .tech-tag {
    @apply rounded-full border border-skin-line px-3 py-1 text-xs opacity-80 transition-colors duration-200 hover:border-skin-accent hover:text-skin-accent;
  }
  .hero-actions {
    @apply mt-6 flex flex-wrap items-center gap-4;
  }
  :global(.hero-cta) {
    @apply font-medium;
  }
  .social-wrapper {
    @apply mt-5;
  }
  section {
    @apply py-8;
  }
  .section-link {
    @apply mt-6 text-center;
  }
  #recent-posts ul {
    @apply list-none p-0;
  }
</style>
