---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";
import Card from "@components/Card";
import Socials from "@components/Socials.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ExperienceTimeline from "@components/ExperienceTimeline.astro";
import ArticleList from "@components/ArticleList.astro";
import getSortedPosts from "@utils/getSortedPosts";
import RecentPhotos from "@components/gallery/RecentPhotos.svelte";
import { getContentSlug } from "@utils/getContentSlug";
import { fetchRecentPhotos, recentPhotos } from "../stores/galleryStore";
import { profile } from "@data/profile";
import { experience } from "@data/experience";
import { articles } from "@data/articles";

type UnsplashPhoto = {
  id: string;
  width: number;
  height: number;
  alt_description?: string | null;
  description?: string | null;
  urls: {
    full: string;
    thumb: string;
  };
};

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

await fetchRecentPhotos(8);
const recentPhotoItems = Object.values(
  recentPhotos.get() as Record<string, UnsplashPhoto>
).map(photo => ({
  id: photo.id,
  width: photo.width,
  height: photo.height,
  alt: photo.alt_description ?? photo.description ?? "",
  urls: {
    full: photo.urls.full,
    thumb: photo.urls.thumb,
  },
}));
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <!-- <h1>{profile.name}</h1>
      <p class="hero-subtitle">
        {profile.title} · {profile.location}
      </p> -->
      <p>{profile.bio}</p>
      <div class="social-wrapper">
        <Socials />
      </div>
    </section>

    <Hr />

    <section id="gallery">
      <SectionHeading title="Photos" />
      <RecentPhotos photos={recentPhotoItems} client:load />
      <div class="section-link">
        <LinkButton href="/gallery/" showArrow={true}>Gallery</LinkButton>
      </div>
    </section>

    <Hr />

    <!-- <section id="technologies">
      <SectionHeading title="Technologies" />
      <TechTags />
    </section>

    <Hr /> -->

    <section id="experience">
      <SectionHeading title="Experience" />
      <ExperienceTimeline entries={experience} limit={2} />
      <div class="section-link">
        <LinkButton href="/experience/" showArrow={true}>
          Full experience
        </LinkButton>
      </div>
    </section>

    <Hr />

    <section id="writing">
      <SectionHeading title="Writing" />
      <ArticleList entries={articles} limit={3} />
      <div class="section-link">
        <LinkButton href="https://medium.com/@hendrikprinsza" showArrow={true}>
          All articles on Medium
        </LinkButton>
      </div>
    </section>

    {
      recentPosts.length > 0 && (
        <>
          <Hr />
          <section id="recent-posts">
            <SectionHeading title="Recent posts" />
            {recentPosts.length > 0 && (
              <ul>
                {recentPosts.map(
                  (post, index) =>
                    index < 4 && (
                      <Card
                        href={`/posts/${getContentSlug(post)}/`}
                        frontmatter={post.data}
                        secHeading={false}
                      />
                    )
                )}
              </ul>
            )}
            <div class="section-link">
              <LinkButton href="/posts/" showArrow={true}>
                All posts
              </LinkButton>
            </div>
          </section>
        </>
      )
    }
  </main>

  <Footer />
</Layout>

<style>
  #hero {
    @apply pb-6 pt-8;
  }
  #hero h1 {
    @apply text-3xl font-bold sm:text-4xl;
  }
  .hero-subtitle {
    @apply text-skin-accent;
  }
  #hero p {
    @apply my-3;
  }
  .social-wrapper {
    @apply mt-4;
  }
  section {
    @apply py-6;
  }
  .section-link {
    @apply mt-6 text-center;
  }
  #recent-posts ul {
    @apply list-none p-0;
  }
</style>
