---
import type { ArticleEntry } from "@data/articles";

export interface Props {
  entries: ArticleEntry[];
  limit?: number;
}

const { entries, limit } = Astro.props;
const items = limit === undefined ? entries : entries.slice(0, limit);
---

<ul class="article-list">
  {
    items.map(entry => (
      <li class="article-item">
        <a
          href={entry.url}
          target="_blank"
          rel="noopener noreferrer"
          class="article-link"
        >
          <h3 class="article-title">{entry.title}</h3>
        </a>
        <span class="article-date">{entry.date}</span>
        <p class="article-description">{entry.description}</p>
      </li>
    ))
  }
</ul>

<style>
  .article-list {
    @apply list-none space-y-4 p-0;
  }
  .article-item {
    @apply rounded-lg border border-transparent px-3 py-3 transition-colors duration-200 -mx-3 last:border-b-0 last:pb-3 hover:border-skin-line hover:bg-skin-card hover:bg-opacity-30;
  }
  .article-title {
    @apply text-base font-medium text-skin-accent decoration-dashed hover:underline;
  }
  .article-date {
    @apply text-sm opacity-70;
  }
  .article-description {
    @apply mt-1 text-sm opacity-90;
  }
</style>
