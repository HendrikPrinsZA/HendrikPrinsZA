---
export interface Props {
  title: string;
  id?: string;
}

const { title, id } = Astro.props;
---

<h2 {id} class="section-heading">{title}</h2>

<style>
  .section-heading {
    @apply mb-6 text-2xl font-semibold tracking-tight;
  }
  .section-heading::after {
    content: "";
    @apply mt-3 block h-px w-12 bg-skin-accent opacity-40;
  }
</style>
