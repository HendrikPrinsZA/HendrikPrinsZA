---
export interface Props {
  href: string;
  className?: string;
  ariaLabel?: string;
  title?: string;
  disabled?: boolean;
  showArrow?: boolean;
}

const {
  href,
  className,
  ariaLabel,
  title,
  disabled = false,
  showArrow = false,
} = Astro.props;

const isExternalHttp =
  href.startsWith("http://") || href.startsWith("https://");
---

{
  disabled ? (
    <span
      class={`group inline-block ${className}`}
      aria-label={ariaLabel}
      title={title}
      aria-disabled={disabled}
    >
      <slot />
    </span>
  ) : (
    <a
      {href}
      class={`group inline-block hover:text-skin-accent ${className}`}
      aria-label={ariaLabel}
      title={title}
      {...(isExternalHttp && {
        rel: "noopener noreferrer",
        target: "_blank",
      })}
    >
      <slot />

      {showArrow && (
        <svg xmlns="http://www.w3.org/2000/svg" class="arrow-icon">
          <path d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z" />
        </svg>
      )}
    </a>
  )
}

<style>
  .arrow-icon {
    @apply ml-0.5 inline-block transition-transform duration-200 group-hover:translate-x-0.5;
  }
  @media (prefers-reduced-motion: reduce) {
    .arrow-icon {
      @apply transition-none;
    }
  }
</style>
